# Shared defaults
NODE_ENV=development

# Backend
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
JWT_SECRET=change_me_with_long_random_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://bokun-zanzibar-booking.vercel.app
DEFAULT_CURRENCY=USD
BOKUN_BASE_URL=https://api.bokun.io
BOKUN_ACCESS_KEY=replace_with_bokun_access_key
BOKUN_SECRET_KEY=replace_with_bokun_secret_key
BOKUN_API_KEY=
BOKUN_TIMEOUT_MS=30000
BOKUN_RETRY_COUNT=2
BOKUN_MOCK_MODE=true
BOKUN_WEBHOOK_SECRET=
BOKUN_BOOKING_SYNC_ENABLED=false
BOKUN_BOOKING_SYNC_INTERVAL_SECONDS=300
BOKUN_BOOKING_SYNC_BATCH_SIZE=20

# Pesapal (V3 API)
PESAPAL_BASE_URL=https://pay.pesapal.com/v3/api
PESAPAL_AUTH_PATH=/Auth/RequestToken
PESAPAL_SUBMIT_ORDER_PATH=/Transactions/SubmitOrderRequest
PESAPAL_STATUS_PATH=/Transactions/GetTransactionStatus
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# Use PUBLIC URLs in live mode (localhost/127.0.0.1 will be blocked unless overridden)
PESAPAL_SUCCESS_URL=https://your-public-domain.com/payment-success
PESAPAL_CANCEL_URL=https://your-public-domain.com/payment-failure
PESAPAL_CALLBACK_URL=
PESAPAL_IPN_ID=
PESAPAL_TIMEOUT_MS=20000
PESAPAL_MOCK_MODE=true
PESAPAL_ALLOW_LOCAL_REDIRECTS=false

GLOBAL_AGENT_COMMISSION_PERCENT=10
QUOTE_TTL_MINUTES=15
TAX_PERCENT=0

# Frontend
VITE_API_BASE_URL=https://bokun-zanzibar-booking.onrender.com
